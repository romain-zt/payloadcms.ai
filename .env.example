# ─── LLM Providers ───────────────────────────────────────
# At least one required. Both supported — chosen at runtime.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# Default model (override per request)
AI_MODEL=gpt-4o
# AI_MODEL=claude-sonnet-4-20250514

# ─── PayloadCMS Instance ─────────────────────────────────
# Your existing Payload instance
PAYLOAD_API_URL=https://your-payload.com
PAYLOAD_API_KEY=your-payload-api-key

# ─── Stripe ──────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price ID for Pro plan (create in Stripe dashboard)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# ─── URLs ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Vercel (auto-set on deploy) ─────────────────────────
# VERCEL_URL is set automatically
